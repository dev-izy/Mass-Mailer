{
  "name": "mass-mailer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "process-emails": "node scripts/send-email.js",
    "process-emails:watch": "node scripts/send-email.js && sleep 5 && npm run process-emails:watch",
    "start:all": "concurrently \"npm run dev\" \"npm run process-emails:watch\""
  },

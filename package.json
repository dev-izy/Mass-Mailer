    "@types/xlsx": "^0.0.35",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "papaparse": "^5.5.4",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
